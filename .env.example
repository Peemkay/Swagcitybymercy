# Copy this file to .env and fill in real values for production.
# This project reads plain OS environment variables. On PythonAnywhere set
# them in the WSGI file (os.environ[...]) or load a .env with python-dotenv.

# Generate a fresh key with:
#   python manage.py shell -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=replace-this-with-a-long-random-50-char-string

DJANGO_DEBUG=False

# Bare hostnames only — NO scheme, NO trailing slash, comma-separated.
# PythonAnywhere free accounts have no "www." subdomain.
DJANGO_ALLOWED_HOSTS=swagcitybymercy.pythonanywhere.com

# CSRF origins DO include the scheme (https://).
DJANGO_CSRF_TRUSTED_ORIGINS=https://swagcitybymercy.pythonanywhere.com

# PythonAnywhere terminates HTTPS at its proxy, so this is safe to leave on.
DJANGO_SECURE_SSL_REDIRECT=True
